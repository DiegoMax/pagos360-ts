{
	"name": "@diegomax/pagos360",
	"version": "0.1.1",
	"description": "TypeScript client for the Pagos360 API.",
	"type": "module",
	"author": "Diego Massanti <diego@massanti.com>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/DiegoMax/pagos360-ts.git"
	},
	"bugs": {
		"url": "https://github.com/DiegoMax/pagos360-ts/issues"
	},
	"homepage": "https://github.com/DiegoMax/pagos360-ts#readme",
	"engines": {
		"node": ">=22"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.check.json --noEmit",
		"test": "vitest run",
		"test:watch": "vitest"
	},
	"keywords": [
		"pagos360",
		"payments",
		"gateway",
		"typescript",
		"argentina"
	],
	"dependencies": {
		"zod": "^3.25.28"
	},
	"devDependencies": {
		"@types/node": "^24.6.0",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	}
}
